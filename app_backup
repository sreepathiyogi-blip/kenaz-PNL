# ─── Helpers ──────────────────────────────────────────────────────────────────
def xlsb_to_date(n):
    try:
        return date(1899, 12, 30) + timedelta(days=int(float(n)))
    except Exception:
        return None

def fmt_lacs(v, decimals=2):
    if pd.isna(v) or v == 0:
        return "–"
    return f"₹{v/100000:,.{decimals}f}L"

def fmt_pct(v):
    if pd.isna(v):
        return "–"
    return f"{v:.1f}%"

def color_pct(v, inverse=False):
    if pd.isna(v):
        return ""
    good = v >= 0
    if inverse:
        good = not good
    return "positive" if good else "negative"


# ─── Data loader ──────────────────────────────────────────────────────────────
@st.cache_data(show_spinner="Reading file…")
def load_data(file_bytes: bytes) -> pd.DataFrame:
    import tempfile, os
    with tempfile.NamedTemporaryFile(suffix=".xlsb", delete=False) as tmp:
        tmp.write(file_bytes)
        tmp_path = tmp.name

    rows = []
    with open_workbook(tmp_path) as wb:
        with wb.get_sheet("For P&L") as ws:
            for row in ws.rows():
                rows.append([c.v for c in row])
    os.unlink(tmp_path)

    headers = rows[4]
    df = pd.DataFrame(rows[5:], columns=headers)

    # keep only data rows
    df = df.dropna(subset=["Sum of Revenue Without Tax"])
    df = df[df["Sum of Revenue Without Tax"].astype(str).str.strip() != ""]
    df = df[pd.to_numeric(df["Sum of Revenue Without Tax"], errors="coerce").notna()]
    df = df[pd.to_numeric(df["Sum of Revenue Without Tax"], errors="coerce") != 0]
    df = df.dropna(subset=["Channel"])
    df = df[df["Channel"].astype(str).isin(["Website","FBA","RK","Meesho","Flipkart","Myntra PPMP"])]

    num_cols = [c for c in df.columns if c and c.startswith("Sum of")]
    for col in num_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)

    df["Month_date"] = df["Month"].apply(xlsb_to_date)
    df["Month_label"] = df["Month_date"].apply(lambda d: d.strftime("%b-%y") if d else "Unknown")
    df["Month_sort"]  = df["Month_date"].apply(lambda d: d.strftime("%Y-%m") if d else "9999-99")

    # rename for display
    df = df.rename(columns={
        "Sum of Revenue Without Tax": "Net Sales",
        "Sum of COGS":               "COGS",
        "Sum of Inward":             "Freight Inward",
        "Sum of Wages":              "Wages",
        "Sum of commission":         "Commission",
        "Sum of Payment Gateway":    "Payment Gateway",
        "Sum of Shipping":           "Shipping",
        "Sum of others":             "Others",
        "Sum of Total Spend":        "Ad Spend",
        "Sum of Bulk Logistic Cost": "Bulk Logistic",
        "Sum of Packaging Cost":     "Packaging",
        "Sum of Warehousing Charges":"Warehousing",
        "Sum of TOTAL MRP":          "MRP Sales",
        "Sum of Qty":                "Quantity",
    })

    df["GM"]   = df["Net Sales"] - df["COGS"] - df["Freight Inward"] - df["Wages"]
    df["CM1"]  = df["GM"] - df["Commission"] - df["Payment Gateway"] - df["Shipping"] - df["Others"] - df["Bulk Logistic"] - df["Packaging"] - df["Warehousing"]
    df["CM2"]  = df["CM1"] - df["Ad Spend"]
    df["COGS%"] = (df["COGS"] / df["Net Sales"] * 100).replace([np.inf, -np.inf], 0)
    df["GM%"]   = (df["GM"]  / df["Net Sales"] * 100).replace([np.inf, -np.inf], 0)
    df["CM1%"]  = (df["CM1"] / df["Net Sales"] * 100).replace([np.inf, -np.inf], 0)
    df["CM2%"]  = (df["CM2"] / df["Net Sales"] * 100).replace([np.inf, -np.inf], 0)

    return df


