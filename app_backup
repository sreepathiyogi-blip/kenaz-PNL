            color = "positive" if (pct>=0) != inverse else "negative"
            vals.append(f"<td><span class='{color}'>{fmt_lacs(v)}</span><br><span class='percent'>{fmt_pct(pct)}</span></td>")
        tv = total[key]; tn = total["Net Sales"]
