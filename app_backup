        vals.append(f"<td><span class='{tc}'>{fmt_lacs(tv)}</span><br><span class='percent'>{fmt_pct(tp)}</span></td>")
        return f"<tr class='{cls}'><td>{label}</td>{''.join(vals)}</tr>"

    heads = "".join(f"<th>{ch}</th>" for ch in channels) + "<th>Total</th>"
